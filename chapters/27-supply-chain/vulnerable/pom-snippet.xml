<!--
  VULNERABLE — drop the following <dependency> into backend/pom.xml
  inside the <dependencies> block.

  log4j-core 2.14.1 has CVE-2021-44228 (Log4Shell), CVSS 10.0.
  Spring Boot 3.x doesn't normally pull log4j-core, but adding it
  explicitly (or having a transitive that pins this version) is enough.
  The point of this chapter is to show what `mvn dependency-check:check`
  reports when a known-vulnerable artifact is on the classpath.
-->
<dependency>
  <groupId>org.apache.logging.log4j</groupId>
  <artifactId>log4j-core</artifactId>
  <version>2.14.1</version>
</dependency>

<!--
  Bonus targets for the scanner — common older artifacts that still
  appear in production poms and have published CVEs:
-->
<dependency>
  <groupId>com.fasterxml.jackson.core</groupId>
  <artifactId>jackson-databind</artifactId>
  <version>2.9.10</version>      <!-- many serialization CVEs -->
</dependency>
<dependency>
  <groupId>commons-collections</groupId>
  <artifactId>commons-collections</artifactId>
  <version>3.2.1</version>      <!-- CVE-2015-7501 RCE -->
</dependency>
